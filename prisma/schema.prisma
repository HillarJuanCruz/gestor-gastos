generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Gasto {
  id          String   @id @default(uuid())
  descripcion String
  monto       Decimal  @db.Decimal(12, 2)
  categoria   String
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())

  user_id      String @db.Uuid

  @@map("gastos") // Para que en la DB la tabla se llame "gastos" en minúscula
}
